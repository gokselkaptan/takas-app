{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.takas-a.com" }],
      "destination": "https://takas-a.com/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "app/api/admin/revalue-products/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/revalue/route.ts": {
      "maxDuration": 300
    }
  },
  "installCommand": "npm install && rm -f yarn.lock && touch yarn.lock",
  "buildCommand": "prisma generate && next build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "crons": [
    { "path": "/api/keep-alive", "schedule": "*/4 * * * *" },
    { "path": "/api/cron/wishboard-matching", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/multi-swap-reminders", "schedule": "*/30 * * * *" },
    { "path": "/api/swap-requests/auto-cancel", "schedule": "0 */4 * * *" },
    { "path": "/api/cron/overdue-swaps", "schedule": "0 9,15,21 * * *" }
  ]
}
